{
  "manifest_version": 3,
  "name": "Leak",
  "version": "1.0",
  "description": "Leak homework helper",
  "action": {
  },
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://141.147.118.157:5678/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://app.senecalearning.com/login/*"
      ],
      "js": [
        "seneca/auth/index.js",
        "seneca/universal.js"
      ],
      "css": [
        "seneca/universal.css",
        "seneca/auth/index.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://app.senecalearning.com/dashboard/*",
        "*://app.senecalearning.com/dashboard"
      ],
      "js": [
        "seneca/app/index.js",
        "seneca/universal.js"
      ],
      "css": [
        "seneca/universal.css",
        "seneca/app/index.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://maths.sparx-learning.com/*"
      ],
      "js": [
        "sparx/maths/index.js",
        "sparx/universal.js"
      ],
      "css": [
        "sparx/universal.css",
        "sparx/maths/index.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://reader.sparx-learning.com/*"
      ],
      "js": [
        "sparx/reader/index.js",
        "sparx/universal.js"
      ],
      "css": [
        "sparx/universal.css",
        "sparx/reader/index.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://science.sparx-learning.com/*"
      ],
      "js": [
        "sparx/science/index.js",
        "sparx/universal.js"
      ],
      "css": [
        "sparx/universal.css",
        "sparx/science/index.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://auth.sparx-learning.com/*"
      ],
      "js": [
        "sparx/auth/index.js",
        "sparx/universal.js"
      ],
      "css": [
        "sparx/universal.css",
        "sparx/auth/index.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "universal/leak_menu.js",
        "universal/ai/chatbot.js"
      ],
      "css": [
        "universal/leak_menu.css",
        "universal/ai/chatbot.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
